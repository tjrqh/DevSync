    private string GetMessageClass(ChatMessageDto message)
    {
        var className = message.IsSystem ? "message system" : "message";
        return IsMentionedMe(message) ? $"{className} mentioned" : className;
    }

    private MarkupString RenderMentionText(string content)
    {
        var encoded = System.Net.WebUtility.HtmlEncode(content);
        foreach (var member in ApprovedMembers)
        {
            var mention = $"@{member.DisplayName}";
            var encodedMention = System.Net.WebUtility.HtmlEncode(mention);
            var mentionClass = member.UserId == currentUser?.UserId ? "my-mention" : "plain-mention";
            encoded = encoded.Replace(encodedMention, $"<span class=\"{mentionClass}\">{encodedMention}</span>", StringComparison.OrdinalIgnoreCase);
        }

        return new MarkupString(encoded);
    }

