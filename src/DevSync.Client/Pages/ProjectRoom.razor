    private void ToggleTaskModal()
    {
        showTaskModal = !showTaskModal;
        if (!showTaskModal)
        {
            ResetModalForm();
        }
    }

    private void ResetModalForm()
    {
        modalTaskTitle = "";
        modalTaskDescription = "";
        modalTaskDueDate = null;
        modalTaskPriority = "High";
        modalTaskAssigneeUserId = "";
        modalTaskStatusString = "Todo";
    }

    private async Task CreateTaskFromModalAsync()
    {
        if (currentUser is null || string.IsNullOrWhiteSpace(modalTaskTitle))
        {
            return;
        }

        isBusy = true;
        errorMessage = null;

        try
        {
            var selectedStatus = Enum.Parse<ProjectTaskStatus>(modalTaskStatusString);
            var assigneeUserId = int.TryParse(modalTaskAssigneeUserId, out var parsedAssigneeUserId)
                ? parsedAssigneeUserId
                : (int?)null;

            var response = await Http.PostAsJsonAsync(
                $"api/rooms/{activeRoomId}/tasks?userId={currentUser.UserId}",
                new CreateProjectTaskRequest(
                    modalTaskTitle,
                    string.IsNullOrWhiteSpace(modalTaskDescription) ? null : modalTaskDescription,
                    assigneeUserId,
                    modalTaskPriority,
                    modalTaskDueDate,
                    selectedStatus));

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await response.Content.ReadAsStringAsync();
                return;
            }

            var createdTask = await response.Content.ReadFromJsonAsync<ProjectTaskDto>();
            if (createdTask is not null)
            {
                var existingIndex = tasks.FindIndex(x => x.Id == createdTask.Id);
                if (existingIndex >= 0)
                {
                    tasks[existingIndex] = createdTask;
                }
                else
                {
                    tasks.Add(createdTask);
                }
            }

            ToggleTaskModal();
        }
        catch (Exception ex)
        {
            errorMessage = $"작업 생성 실패: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private sealed record AppNotification(
        int Id,
        int UserId,
        int RoomId,
        string RoomName,
        int? ChatMessageId,
        string Type,
        string Title,
        string Body,
        DateTimeOffset CreatedAt,
        bool IsRead);
}
