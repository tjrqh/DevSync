    private void ClearDragOver(ProjectTaskStatus status)
    {
        if (dragOverStatus == status)
        {
            dragOverStatus = null;
        }
    }

    private async Task DropTaskAsync(ProjectTaskStatus newStatus)
    {
        if (draggedTaskId is null)
        {
            return;
        }

        var taskIndex = tasks.FindIndex(x => x.Id == draggedTaskId.Value);
        if (taskIndex < 0)
        {
            ClearDrag();
            return;
        }

        var task = tasks[taskIndex];
        var oldStatus = task.Status;
        ClearDrag();

        if (oldStatus == newStatus)
        {
            return;
        }

        tasks[taskIndex] = task with { Status = newStatus };
        StateHasChanged();

        if (currentUser is null)
        {
            return;
        }

        var response = await Http.PatchAsJsonAsync(
            $"api/rooms/{activeRoomId}/tasks/{task.Id}/status",
            new UpdateTaskStatusRequest(currentUser.UserId, newStatus));

        if (!response.IsSuccessStatusCode)
        {
            errorMessage = await response.Content.ReadAsStringAsync();
            var rollbackIndex = tasks.FindIndex(x => x.Id == task.Id);
            if (rollbackIndex >= 0)
            {
                tasks[rollbackIndex] = tasks[rollbackIndex] with { Status = oldStatus };
            }
        }
    }

